# Optional override if the DB middleware is served from another origin.
VITE_MAHALA_DB_BASE_URL=""

# Optional direct DB overrides for the geoeditor server.
# If omitted, the editor falls back to ../mahala-backend/.env and then process.env.
MAHALA_DB_HOST="127.0.0.1"
MAHALA_DB_PORT="3306"
MAHALA_DB_DATABASE="mahala"
MAHALA_DB_USERNAME="root"
MAHALA_DB_PASSWORD=""
